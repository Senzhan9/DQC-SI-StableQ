# GitHub Pages compatible Gemfile.
# GitHub Pages builds Jekyll for you automatically, so locally you only need
# this to preview. To preview:
#   bundle install
#   bundle exec jekyll serve
# Then open http://localhost:4000

source "https://rubygems.org"
gem "github-pages", group: :jekyll_plugins
gem "webrick", "~> 1.8" # required on Ruby 3.0+
